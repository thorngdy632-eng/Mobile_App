rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ==========================================
    // 1. LOCATIONS RULE
    // ==========================================
    match /locations/{locationId} {
      allow read, create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // ==========================================
    // 2. USERS COLLECTION
    // ==========================================
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ==========================================
    // 3. CHATS & MESSAGES COLLECTION
    // ==========================================
    match /chats/{chatId} {
      allow read, update, delete: if request.auth != null && request.auth.uid in resource.data.participants;
      allow create: if request.auth != null;

      match /messages/{messageId} {
        allow read, write: if request.auth != null && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }

    // ==========================================
    // 4. SERVICE REQUESTS COLLECTION
    // ==========================================
    match /serviceRequests/{requestId} {
      allow read, create: if request.auth != null;
      // Any authenticated user can update (app handles service-type matching).
      // The provider who accepted the job can also update (complete / give up).
      allow update: if request.auth != null;
      allow delete: if request.auth != null && request.auth.uid == resource.data.farmerUid;
    }

    // ==========================================
    // 5. TRACTOR JOBS COLLECTION
    // ==========================================
    match /tractorJobs/{jobId} {
      allow read, create: if request.auth != null;
      allow update, delete: if request.auth != null;
    }

    // ==========================================
    // 6. DRONE JOBS COLLECTION
    // ==========================================
    match /droneJobs/{jobId} {
      allow read, create: if request.auth != null;
      allow update, delete: if request.auth != null;
    }

  }
}
